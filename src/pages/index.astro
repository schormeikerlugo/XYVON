---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Marquee from '../components/Marquee.astro';
import Problem from '../components/Problem.astro';
import Products from '../components/Products.astro';
import Science from '../components/Science.astro';
import Gallery from '../components/Gallery.astro';
import Founder from '../components/Founder.astro';
import Substack from '../components/Substack.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';
import BackToTop from '../components/BackToTop.astro';
import { products, site } from '../data/site';

// JSON-LD for homepage — ItemList of products for rich results
const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${site.name} — Electrolyte System`,
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Product',
      name: `XYVON ${p.name}`,
      description: p.description,
      brand: { '@type': 'Brand', name: site.name },
      category: 'Electrolyte Supplement',
      image: `${site.url}${p.image}`,
      url: `${site.url}/#${p.id}`,
      offers: {
        '@type': 'Offer',
        priceCurrency: 'EUR',
        price: p.price.replace('€', ''),
        availability:
          p.status === 'available'
            ? 'https://schema.org/InStock'
            : 'https://schema.org/PreOrder',
      },
    },
  })),
};
---

<BaseLayout
  title="Science-Led Electrolytes Built Around Biology"
  description="XYVON is a science-led electrolyte system — BALANCE, SHIFT, PERFORM, RECOVER, HIM — designed around menstrual cycle, menopause, training, and recovery. EU GMP Vitema manufacturing, zero sugar, evidence-graded doses."
>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

  <Header />

  <main id="main">
    <Hero />
    <Marquee />
    <Problem />
    <Products />
    <Science />
    <Gallery />
    <Founder />
    <Substack />
    <Cta />
  </main>

  <Footer />
  <BackToTop />
</BaseLayout>
