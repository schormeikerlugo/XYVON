---
import { ingredients } from '../data/site';
---

<section class="science" id="science" aria-labelledby="science-title">
  <div class="wrap">
    <header class="science__head">
      <p class="eyebrow reveal">The Science · Why This Dose</p>
      <h2 id="science-title" class="science__title split">
        {'Every milligram'.split(' ').map((w) => (<span class="split__word"><span>{w}</span></span>))}
        <br />
        <em>
          {'has a reason.'.split(' ').map((w) => (<span class="split__word"><span>{w}</span></span>))}
        </em>
      </h2>
      <p class="science__lead reveal" data-stagger="2">
        XYVON's single most distinctive product feature: every ingredient
        amount is accompanied by its evidence grade and a two-to-three
        sentence rationale. No pixie-dusting. No proprietary blends.
      </p>
    </header>

    <div class="science__layout">
      <!-- Left: video + lab backdrop -->
      <div class="science__visual reveal">
        <video
          class="science__video"
          autoplay
          muted
          loop
          playsinline
          disablepictureinpicture
          preload="metadata"
          poster="/images/science-poster.jpg"
        >
          <source src="/videos/science-mobile.mp4" type="video/mp4" media="(max-width: 768px)" />
          <source src="/videos/science.webm" type="video/webm" />
          <source src="/videos/science.mp4" type="video/mp4" />
        </video>
        <div class="science__visual-veil"></div>
        <div class="science__visual-badge">
          <div class="science__visual-badge-inner">
            <span class="caps--wide">EU GMP</span>
            <strong>Vitema</strong>
            <span class="science__visual-small">Certificate of Analysis on every PDP</span>
          </div>
        </div>

        <div class="science__visual-stamp">
          <svg viewBox="0 0 200 200" aria-hidden="true">
            <defs>
              <path id="curve" d="M 100, 100 m -80, 0 a 80,80 0 1,1 160,0 a 80,80 0 1,1 -160,0" />
            </defs>
            <text font-family="Montserrat, sans-serif" font-size="13" letter-spacing="6" fill="#d99959">
              <textPath href="#curve">SCIENCE-LED ELECTROLYTES · VITEMA EU GMP · SCIENCE-LED ELECTROLYTES ·</textPath>
            </text>
          </svg>
        </div>
      </div>

      <!-- Right: ingredient ledger -->
      <div class="science__ledger">
        {ingredients.map((ing, i) => (
          <details class="ingredient reveal" data-stagger={i + 1} open={i === 0}>
            <summary class="ingredient__sum">
              <span class="ingredient__formula">{ing.formula}</span>
              <span class="ingredient__name">{ing.name}</span>
              <span class="ingredient__form">{ing.form}</span>
              <span class="ingredient__grade">{ing.grade}</span>
              <span class="ingredient__icon" aria-hidden="true">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.2">
                  <path d="M3 4l3 3 3-3" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </summary>
            <p class="ingredient__note">{ing.note}</p>
          </details>
        ))}

        <a href="#substack" class="science__more" data-hover>
          <span>Want the full evidence review? Read our Substack.</span>
          <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.3" aria-hidden="true">
            <path d="M1 7h12M8 2l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .science {
    background: var(--xyv-black-deep);
    position: relative;
    border-top: 1px solid var(--xyv-line);
  }

  .science__head {
    max-width: 72ch;
    margin-bottom: var(--sp-9);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4);
  }

  .science__title {
    font-size: var(--fs-display);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 600;
  }

  .science__title em {
    font-style: italic;
    font-weight: 300;
    color: var(--xyv-copper);
  }

  .science__lead {
    color: var(--ink-muted);
    font-size: var(--fs-lead);
    max-width: 60ch;
  }

  .science__layout {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--sp-7);
    align-items: stretch;
  }

  /* ---------- Visual ---------- */
  .science__visual {
    position: relative;
    aspect-ratio: 4/5;
    overflow: hidden;
    border-radius: var(--r-lg);
    background: var(--xyv-black-soft);
    box-shadow: var(--shadow-lg), var(--shadow-inset);
  }

  .science__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(0.75) contrast(1.05) saturate(0.7);
    opacity: 0.55;
  }

  .science__visual-veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(11, 11, 12, 0.2) 0%, rgba(11, 11, 12, 0.8) 100%),
      radial-gradient(circle at 30% 40%, rgba(184, 115, 51, 0.2), transparent 60%);
  }

  .science__visual-badge {
    position: absolute;
    top: var(--sp-5);
    left: var(--sp-5);
    padding: var(--sp-3) var(--sp-5);
    border: 1px solid var(--xyv-copper);
    border-radius: var(--r-sm);
    background: rgba(11, 11, 12, 0.55);
    backdrop-filter: blur(8px);
  }

  .science__visual-badge-inner {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .science__visual-badge strong {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.01em;
    color: var(--xyv-copper);
  }

  .science__visual-badge-inner .caps--wide {
    color: var(--xyv-off-white);
    font-size: 0.6rem;
  }

  .science__visual-small {
    font-size: 0.65rem;
    color: var(--ink-muted);
    margin-top: 2px;
  }

  .science__visual-stamp {
    position: absolute;
    right: var(--sp-4);
    bottom: var(--sp-4);
    width: clamp(96px, 12vw, 140px);
    aspect-ratio: 1;
    animation: rotate-soft 40s linear infinite;
  }

  .science__visual-stamp svg { width: 100%; height: 100%; }

  /* ---------- Ledger ---------- */
  .science__ledger {
    display: flex;
    flex-direction: column;
    gap: var(--sp-3);
  }

  .ingredient {
    border: 1px solid var(--xyv-line);
    border-radius: var(--r-md);
    overflow: hidden;
    transition: border-color var(--dur-med) var(--ease-smooth), background var(--dur-med) var(--ease-smooth);
  }

  .ingredient:hover { border-color: var(--xyv-copper); }

  .ingredient__sum {
    display: grid;
    grid-template-columns: 56px minmax(0, 1fr) auto 18px;
    grid-template-areas:
      'formula name   grade icon'
      'formula form   form  form';
    align-items: center;
    column-gap: var(--sp-4);
    row-gap: var(--sp-1);
    padding: var(--sp-5);
    cursor: pointer;
    list-style: none;
    position: relative;
  }

  .ingredient__sum::-webkit-details-marker { display: none; }

  .ingredient__formula {
    grid-area: formula;
    justify-self: start;
    align-self: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 44px;
    height: 44px;
    padding: 0 0.5em;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1rem;
    line-height: 1;
    color: var(--xyv-copper);
    letter-spacing: 0.02em;
    border: 1px solid color-mix(in srgb, var(--xyv-copper) 40%, transparent);
    border-radius: var(--r-sm);
    background: color-mix(in srgb, var(--xyv-copper) 10%, transparent);
    white-space: nowrap;
  }

  .ingredient__name {
    grid-area: name;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: var(--fs-h3);
    letter-spacing: -0.01em;
    min-width: 0;
  }

  .ingredient__form {
    grid-area: form;
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--ink-faint);
  }

  .ingredient__grade {
    grid-area: grade;
    justify-self: end;
    font-size: 0.65rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    padding: 0.35em 0.75em;
    border: 1px solid var(--xyv-copper);
    color: var(--xyv-copper);
    border-radius: var(--r-pill);
    white-space: nowrap;
  }

  .ingredient__icon {
    grid-area: icon;
    justify-self: end;
    transition: transform var(--dur-med) var(--ease-out);
    color: var(--ink-muted);
  }

  .ingredient[open] .ingredient__icon { transform: rotate(180deg); }

  .ingredient__note {
    padding: 0 var(--sp-5) var(--sp-5);
    color: var(--ink-muted);
    border-top: 1px solid var(--xyv-line);
    padding-top: var(--sp-5);
    margin-top: calc(var(--sp-2) * -1);
  }

  .science__more {
    margin-top: var(--sp-4);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-4) var(--sp-5);
    background: var(--xyv-black-soft);
    border: 1px solid var(--xyv-line);
    border-radius: var(--r-md);
    font-size: var(--fs-small);
    color: var(--xyv-off-white);
    transition: border-color var(--dur-med) var(--ease-smooth), color var(--dur-med) var(--ease-smooth);
  }

  .science__more:hover {
    border-color: var(--xyv-copper);
    color: var(--xyv-copper);
  }

  @media (max-width: 960px) {
    .science__layout { grid-template-columns: 1fr; }
    .science__visual { aspect-ratio: 4/3; }
  }

  @media (max-width: 640px) {
    .science__head { align-items: center; text-align: center; }
    .science__title { margin-inline: auto; }
    .science__lead { margin-inline: auto; }
    .science__more { text-align: center; justify-content: center; }
  }

  @media (max-width: 520px) {
    .ingredient__sum {
      padding: var(--sp-4);
      grid-template-columns: 44px minmax(0, 1fr) auto;
      grid-template-areas:
        'formula name  icon'
        'formula form  form'
        'formula grade grade';
    }
    .ingredient__grade { justify-self: start; }
    .ingredient__name { font-size: var(--fs-body); }
  }
</style>
