---
import { site } from '../data/site';
---

<header class="header" data-header>
  <div class="header__inner wrap">
    <a href="#top" class="header__logo" aria-label={`${site.name} home`}>
      <span class="header__wordmark">XYVON</span>
      <span class="header__dot" aria-hidden="true"></span>
    </a>

    <nav class="header__nav" aria-label="Primary">
      <ul class="header__list">
        {site.nav.map((item) => (
          <li>
            <a href={item.href}>{item.label}</a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__cta">
      <a href="#balance" class="header__link">
        <span>Shop</span>
        <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.3">
          <path d="M1 7h12M8 2l5 5-5 5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
      <button class="header__menu" aria-label="Open menu" aria-expanded="false" data-menu-trigger>
        <span></span><span></span>
      </button>
    </div>
  </div>

  <div class="header__overlay" aria-hidden="true"></div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-header);
    mix-blend-mode: normal;
    transform: translate3d(0, 0, 0);
    transition:
      transform 480ms var(--ease-out),
      background 300ms var(--ease-smooth),
      backdrop-filter 300ms var(--ease-smooth),
      border-color 300ms var(--ease-smooth);
    border-bottom: 1px solid transparent;
    will-change: transform, backdrop-filter;
  }

  .header[data-scrolled="true"] {
    background: rgba(11, 11, 12, 0.62);
    backdrop-filter: blur(28px) saturate(1.4);
    border-bottom-color: var(--xyv-line-strong);
    box-shadow:
      0 12px 32px -16px rgba(0, 0, 0, 0.55),
      inset 0 -1px 0 rgba(245, 242, 238, 0.04);
  }

  /* Fallback for browsers that still cannot paint backdrop-filter */
  @supports not ((backdrop-filter: blur(1px)) or (-webkit-backdrop-filter: blur(1px))) {
    .header[data-scrolled="true"] {
      background: rgba(11, 11, 12, 0.94);
    }
  }

  .header[data-hidden="true"] {
    transform: translate3d(0, -110%, 0);
  }

  /* If the user is interacting with the header itself (hover/focus),
     keep it visible even while scrolling. */
  .header:hover,
  .header:focus-within {
    transform: translate3d(0, 0, 0) !important;
  }

  .header__inner {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: var(--sp-6);
    padding-block: var(--sp-5);
  }

  .header__logo {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
  }

  .header__wordmark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.25rem;
    letter-spacing: var(--tracking-wordmark);
    color: var(--xyv-off-white);
  }

  .header__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--xyv-copper);
    display: inline-block;
    animation: copper-pulse 2.4s var(--ease-in-out) infinite;
  }

  .header__nav {
    justify-self: center;
  }

  .header__list {
    list-style: none;
    display: flex;
    gap: var(--sp-7);
  }

  .header__list a {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    font-weight: 500;
    color: var(--ink-muted);
    position: relative;
    padding-block: 0.4em;
  }

  .header__list a::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: 0;
    right: 0;
    height: 1px;
    background: var(--xyv-copper);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--dur-med) var(--ease-out);
  }

  .header__list a:hover {
    color: var(--xyv-off-white);
  }

  .header__list a:hover::after {
    transform: scaleX(1);
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-5);
    justify-self: end;
  }

  .header__link {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    font-weight: 500;
    color: var(--xyv-off-white);
    padding: 0.75em 1.2em;
    border: 1px solid var(--xyv-line-strong);
    border-radius: var(--r-pill);
    transition:
      background var(--dur-med) var(--ease-smooth),
      border-color var(--dur-med) var(--ease-smooth),
      color var(--dur-med) var(--ease-smooth);
  }

  .header__link:hover {
    background: var(--xyv-copper);
    border-color: var(--xyv-copper);
    color: var(--xyv-black-deep);
  }

  .header__menu {
    display: none;
    width: 40px;
    height: 40px;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--xyv-line-strong);
    border-radius: 50%;
    flex-direction: column;
    gap: 5px;
  }

  .header__menu span {
    display: block;
    width: 16px;
    height: 1px;
    background: var(--xyv-off-white);
  }

  @media (max-width: 880px) {
    .header__nav { display: none; }
    .header__menu { display: inline-flex; }
    .header__inner { grid-template-columns: auto 1fr; }
    .header__cta { grid-column: 2; }
  }
</style>
