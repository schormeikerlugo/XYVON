---
import { site } from '../data/site';
---

<section class="hero" id="top" aria-label="XYVON — Science-Led Electrolytes">
  <!-- Ambient layers -->
  <div class="hero__ambient" aria-hidden="true">
    <div class="hero__orb hero__orb--1" data-orb></div>
    <div class="hero__orb hero__orb--2" data-orb></div>
  </div>

  <!-- Video layer -->
  <div class="hero__media" aria-hidden="true">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      disablepictureinpicture
      preload="metadata"
      poster="/images/hero-poster.jpg"
    >
      <!-- Mobile-optimised (slower networks / smaller screens) -->
      <source src="/videos/hero-mobile.mp4" type="video/mp4" media="(max-width: 768px)" />
      <!-- Modern browsers: VP9 WebM (smaller) -->
      <source src="/videos/hero.webm" type="video/webm" />
      <!-- Universal MP4 fallback -->
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero__veil"></div>
    <div class="hero__vignette"></div>
  </div>

  <!-- Top meta bar -->
  <div class="hero__meta wrap">
    <span class="caps--wide">S4 · Visual Identity</span>
    <span class="hero__ping">
      <span class="hero__ping-dot"></span>
      Launching in Romania · Phase 1
    </span>
    <span class="caps--wide">v1.0 · 2026</span>
  </div>

  <!-- Main content -->
  <div class="hero__content wrap">
    <p class="hero__eyebrow reveal">
      <span class="hero__eyebrow-line"></span>
      <span>Science-led · EU GMP · Zero Sugar</span>
    </p>

    <h1 class="hero__title">
      <span class="hero__line">
        <span class="hero__word" style="--d:0ms"><span>Your</span></span>
        <span class="hero__word" style="--d:80ms"><span>body</span></span>
        <span class="hero__word" style="--d:160ms"><span>has</span></span>
      </span>
      <span class="hero__line">
        <span class="hero__word" style="--d:240ms"><span>specific</span></span>
        <span class="hero__word hero__word--accent" style="--d:320ms"><span>needs.</span></span>
      </span>
      <span class="hero__line hero__line--italic">
        <span class="hero__word" style="--d:520ms"><span>We</span></span>
        <span class="hero__word" style="--d:600ms"><span>designed</span></span>
        <span class="hero__word" style="--d:680ms"><span>for</span></span>
        <span class="hero__word" style="--d:760ms"><span>them.</span></span>
      </span>
    </h1>

    <div class="hero__bottom">
      <div class="hero__copy reveal" data-stagger="3">
        <p>
          Not a lifestyle drink. A mineral protocol engineered around
          biology — the menstrual cycle, the training window, the recovery
          hours — with evidence-graded doses printed on the front of every sachet.
        </p>
      </div>

      <div class="hero__actions reveal" data-stagger="4">
        <a href="#products" class="btn btn--copper" data-hover>
          <span>Shop the System</span>
          <svg class="arrow" width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.4" aria-hidden="true">
            <path d="M1 7h12M8 2l5 5-5 5" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a href="#story" class="btn btn--ghost" data-hover>
          <span>Read Our Story</span>
        </a>
      </div>
    </div>

    <!-- Hero stat rail -->
    <div class="hero__rail" aria-hidden="true">
      <div class="hero__stat reveal" data-stagger="2">
        <span class="hero__stat-num">5</span>
        <span class="hero__stat-label">SKUs in System</span>
      </div>
      <div class="hero__stat reveal" data-stagger="3">
        <span class="hero__stat-num">0</span>
        <span class="hero__stat-label">Sugar · Kcal · Fluff</span>
      </div>
      <div class="hero__stat reveal" data-stagger="4">
        <span class="hero__stat-num">EU</span>
        <span class="hero__stat-label">GMP Pharma-grade</span>
      </div>
      <div class="hero__stat reveal" data-stagger="5">
        <span class="hero__stat-num">1:1</span>
        <span class="hero__stat-label">Built by its Founder</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="hero__scroll" aria-hidden="true">
      <span class="caps--wide">Scroll</span>
      <span class="hero__scroll-line"></span>
    </div>
  </div>

  <!-- Giant XYVON wordmark (backdrop) -->
  <div class="hero__wordmark" aria-hidden="true">
    <span>X</span><span>Y</span><span>V</span><span>O</span><span>N</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    padding-top: clamp(5rem, 10vh, 7rem);
    padding-bottom: var(--sp-9);
    isolation: isolate;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: var(--xyv-black-deep);
  }

  /* ---------- Ambient copper orbs ---------- */
  .hero__ambient {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  .hero__orb {
    position: absolute;
    width: 620px;
    height: 620px;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.55;
    mix-blend-mode: screen;
    transition: transform 800ms var(--ease-out);
  }

  .hero__orb--1 {
    top: -10%;
    right: -6%;
    background: radial-gradient(circle, rgba(184, 115, 51, 0.75), rgba(184, 115, 51, 0) 60%);
    animation: orb-drift-1 18s ease-in-out infinite;
  }

  .hero__orb--2 {
    bottom: -12%;
    left: -8%;
    width: 540px;
    height: 540px;
    background: radial-gradient(circle, rgba(217, 153, 89, 0.55), rgba(217, 153, 89, 0) 60%);
    animation: orb-drift-2 22s ease-in-out infinite;
  }

  @keyframes orb-drift-1 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(-6%, 8%, 0) scale(1.08); }
  }

  @keyframes orb-drift-2 {
    0%, 100% { transform: translate3d(0, 0, 0) scale(1); }
    50%      { transform: translate3d(8%, -6%, 0) scale(1.12); }
  }

  /* ---------- Video layer ---------- */
  .hero__media {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
  }

  .hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: slow-zoom 6s var(--ease-out) both;
    filter: grayscale(0.55) contrast(1.08) saturate(0.8);
    opacity: 0.42;
  }

  .hero__veil {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(11, 11, 12, 0.4) 0%, rgba(11, 11, 12, 0.6) 50%, var(--xyv-black-deep) 100%),
      linear-gradient(90deg, rgba(11, 11, 12, 0.85) 0%, rgba(11, 11, 12, 0.2) 45%, rgba(11, 11, 12, 0.35) 100%);
  }

  .hero__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 30%, rgba(11, 11, 12, 0.8) 100%);
  }

  /* ---------- Meta bar ---------- */
  .hero__meta {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    padding-block: var(--sp-4);
    margin-bottom: auto;
    gap: var(--sp-4);
  }

  .hero__ping {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps);
    text-transform: uppercase;
    color: var(--ink-muted);
  }

  .hero__ping-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--xyv-copper);
    box-shadow: 0 0 0 0 rgba(184, 115, 51, 0.5);
    animation: copper-pulse 2s var(--ease-in-out) infinite;
  }

  /* ---------- Main content ---------- */
  .hero__content {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    flex: 1;
    padding-block: var(--sp-8) var(--sp-6);
    gap: var(--sp-8);
  }

  .hero__eyebrow {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-caps-wide);
    text-transform: uppercase;
    font-weight: 500;
    color: var(--xyv-copper);
  }

  .hero__eyebrow-line {
    width: 44px;
    height: 1px;
    background: var(--xyv-copper);
    transform-origin: left;
    animation: line-draw 1s var(--ease-out) 200ms both;
  }

  /* ---------- Title ---------- */
  .hero__title {
    font-family: var(--font-display);
    font-size: var(--fs-hero);
    font-weight: 700;
    line-height: var(--lh-hero);
    letter-spacing: -0.035em;
    max-width: min(22ch, 100%);
    color: var(--xyv-off-white);
  }

  .hero__line {
    display: flex;
    flex-wrap: wrap;
    gap: 0 0.22em;
    overflow: hidden;
    padding-block: 0.02em 0.04em;
  }

  .hero__line--italic {
    font-style: italic;
    font-weight: 300;
    color: var(--ink-muted);
  }

  .hero__word {
    display: inline-block;
    overflow: hidden;
    overflow: clip;
    overflow-clip-margin: 0.2em;
    padding-block: 0.05em 0.15em;
    padding-inline-end: 0.05em;
    vertical-align: baseline;
  }

  .hero__word > span {
    display: inline-block;
    transform: translate3d(0, 110%, 0);
    animation: hero-word-in 1.1s var(--ease-out) var(--d, 0ms) both;
  }

  .hero__word--accent {
    color: var(--xyv-copper);
    font-style: italic;
    font-weight: 300;
  }

  @keyframes hero-word-in {
    0%   { transform: translate3d(0, 110%, 0); filter: blur(6px); }
    60%  { filter: blur(0); }
    100% { transform: translate3d(0, 0, 0); filter: blur(0); }
  }

  /* ---------- Bottom row ---------- */
  .hero__bottom {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) auto;
    gap: var(--sp-7);
    align-items: end;
  }

  .hero__copy p {
    font-size: var(--fs-lead);
    color: var(--ink-muted);
    max-width: 56ch;
    line-height: 1.55;
  }

  .hero__actions {
    display: inline-flex;
    gap: var(--sp-3);
    flex-wrap: wrap;
  }

  /* ---------- Stat rail ---------- */
  .hero__rail {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
    border-top: 1px solid var(--xyv-line);
    border-bottom: 1px solid var(--xyv-line);
  }

  .hero__stat {
    padding: var(--sp-5) 0;
    border-left: 1px solid var(--xyv-line);
    padding-left: var(--sp-5);
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
  }

  .hero__stat:first-child {
    border-left: 0;
    padding-left: 0;
  }

  .hero__stat-num {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2rem, 3.5vw, 3rem);
    letter-spacing: -0.02em;
    color: var(--xyv-off-white);
    line-height: 1;
  }

  .hero__stat-label {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--ink-faint);
  }

  /* ---------- Scroll indicator ---------- */
  .hero__scroll {
    position: absolute;
    right: var(--gutter);
    bottom: var(--sp-6);
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    display: inline-flex;
    align-items: center;
    gap: var(--sp-3);
    color: var(--ink-faint);
    font-size: var(--fs-micro);
  }

  .hero__scroll-line {
    width: 1px;
    height: 60px;
    background: linear-gradient(to top, var(--xyv-copper), transparent);
    position: relative;
    overflow: hidden;
  }

  .hero__scroll-line::after {
    content: '';
    position: absolute;
    left: -1px;
    width: 3px;
    height: 14px;
    background: var(--xyv-copper);
    animation: scroll-run 2.4s var(--ease-in-out) infinite;
  }

  @keyframes scroll-run {
    0%   { top: -14px; opacity: 0; }
    25%  { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }

  /* ---------- Giant wordmark ---------- */
  .hero__wordmark {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -5%;
    display: flex;
    justify-content: space-between;
    padding: 0 var(--gutter);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(6rem, 22vw, 20rem);
    letter-spacing: -0.04em;
    line-height: 0.8;
    color: transparent;
    -webkit-text-stroke: 1px rgba(245, 242, 238, 0.07);
    z-index: 1;
    pointer-events: none;
    user-select: none;
  }

  .hero__wordmark span {
    display: inline-block;
    transform: translateY(20%);
    opacity: 0;
    animation: wm-in 1.4s var(--ease-out) forwards;
  }

  .hero__wordmark span:nth-child(1) { animation-delay: 0.8s; }
  .hero__wordmark span:nth-child(2) { animation-delay: 0.95s; }
  .hero__wordmark span:nth-child(3) { animation-delay: 1.1s; }
  .hero__wordmark span:nth-child(4) { animation-delay: 1.25s; }
  .hero__wordmark span:nth-child(5) { animation-delay: 1.4s; }

  @keyframes wm-in {
    from { transform: translateY(20%); opacity: 0; }
    to   { transform: translateY(0);   opacity: 1; }
  }

  /* ---------- Responsive ---------- */
  @media (max-width: 1000px) {
    .hero__bottom {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .hero__rail {
      grid-template-columns: repeat(2, 1fr);
    }
    .hero__stat:nth-child(3) {
      border-left: 0;
      padding-left: 0;
    }
    .hero__scroll { display: none; }
  }

  @media (max-width: 640px) {
    .hero__meta { font-size: 0.625rem; justify-content: center; gap: var(--sp-3); flex-wrap: wrap; }
    .hero__meta span:nth-child(3) { display: none; }

    .hero__content { align-items: center; text-align: center; }
    .hero__eyebrow { justify-content: center; }
    .hero__title { margin-inline: auto; }
    .hero__line { justify-content: center; }

    .hero__bottom { gap: var(--sp-5); align-items: center; }
    .hero__copy p { margin-inline: auto; }
    .hero__actions { justify-content: center; width: 100%; }

    .hero__rail { grid-template-columns: 1fr 1fr; }
    .hero__stat {
      border-left: 0;
      padding-left: 0;
      align-items: center;
      text-align: center;
      padding-block: var(--sp-4);
    }
    .hero__stat:nth-child(odd) {
      border-right: 1px solid var(--xyv-line);
    }
  }
</style>

<script>
  // Interactive orb magnetics
  const orbs = document.querySelectorAll<HTMLElement>('[data-orb]');
  if (orbs.length && matchMedia('(hover: hover)').matches) {
    window.addEventListener('mousemove', (e) => {
      const x = (e.clientX / window.innerWidth - 0.5) * 2;
      const y = (e.clientY / window.innerHeight - 0.5) * 2;
      orbs.forEach((orb, i) => {
        const factor = i % 2 === 0 ? 30 : -24;
        orb.style.transform = `translate3d(${x * factor}px, ${y * factor}px, 0)`;
      });
    }, { passive: true });
  }
</script>
