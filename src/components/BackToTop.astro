---
---

<button
  type="button"
  class="back-to-top"
  data-back-to-top
  aria-label="Back to top"
  data-hover
>
  <span class="back-to-top__ring" aria-hidden="true"></span>
  <svg class="back-to-top__arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="1.6" aria-hidden="true">
    <path d="M9 15V3M4 8l5-5 5 5" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
  <span class="back-to-top__label caps--wide">Top</span>
</button>

<style>
  .back-to-top {
    position: fixed;
    right: clamp(1rem, 2vw, 1.75rem);
    bottom: clamp(1rem, 2vw, 1.75rem);
    z-index: var(--z-header);
    width: 54px;
    height: 54px;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 2px;
    padding: 0;
    border-radius: 50%;
    background: rgba(11, 11, 12, 0.72);
    color: var(--xyv-off-white);
    border: 1px solid var(--xyv-line-strong);
    backdrop-filter: blur(18px) saturate(1.3);
    box-shadow:
      0 12px 28px -14px rgba(0, 0, 0, 0.6),
      inset 0 0 0 1px rgba(184, 115, 51, 0.12);
    cursor: pointer;
    isolation: isolate;
    transform: translate3d(0, 24px, 0) scale(0.85);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 500ms var(--ease-out),
      opacity 400ms var(--ease-smooth),
      background 300ms var(--ease-smooth),
      border-color 300ms var(--ease-smooth),
      color 300ms var(--ease-smooth);
    will-change: transform, opacity;
  }

  .back-to-top[data-visible="true"] {
    transform: translate3d(0, 0, 0) scale(1);
    opacity: 1;
    pointer-events: auto;
  }

  .back-to-top__ring {
    position: absolute;
    inset: -6px;
    border: 1px solid var(--xyv-copper);
    border-radius: 50%;
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 400ms var(--ease-smooth), transform 500ms var(--ease-out);
    pointer-events: none;
  }

  .back-to-top__arrow {
    position: relative;
    z-index: 1;
    color: var(--xyv-copper);
    transition:
      transform 400ms var(--ease-out),
      color 300ms var(--ease-smooth);
  }

  .back-to-top__label {
    position: relative;
    z-index: 1;
    font-size: 0.55rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    color: var(--ink-muted);
    margin-top: 1px;
    transition: color 300ms var(--ease-smooth);
  }

  .back-to-top:hover,
  .back-to-top:focus-visible {
    background: var(--xyv-copper);
    border-color: var(--xyv-copper);
    color: var(--xyv-black-deep);
  }

  .back-to-top:hover .back-to-top__arrow,
  .back-to-top:focus-visible .back-to-top__arrow {
    color: var(--xyv-black-deep);
    transform: translate3d(0, -3px, 0);
  }

  .back-to-top:hover .back-to-top__label,
  .back-to-top:focus-visible .back-to-top__label {
    color: var(--xyv-black-deep);
  }

  .back-to-top:hover .back-to-top__ring,
  .back-to-top:focus-visible .back-to-top__ring {
    opacity: 0.55;
    transform: scale(1);
    animation: ring-pulse 1.6s var(--ease-out) infinite;
  }

  @keyframes ring-pulse {
    0%   { transform: scale(1);    opacity: 0.55; }
    100% { transform: scale(1.22); opacity: 0; }
  }

  /* When the footer is in view, hide the floating button (footer has its own "Back to top ↑") */
  .back-to-top[data-at-footer="true"] {
    transform: translate3d(0, 32px, 0) scale(0.7) !important;
    opacity: 0 !important;
    pointer-events: none !important;
  }

  @media (max-width: 640px) {
    .back-to-top {
      width: 46px;
      height: 46px;
    }
    .back-to-top__label { display: none; }
    .back-to-top__arrow { width: 16px; height: 16px; }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>('[data-back-to-top]');
  const footer = document.querySelector<HTMLElement>('footer');

  if (btn) {
    // Smooth scroll to top on click
    btn.addEventListener('click', () => {
      if ('scrollBehavior' in document.documentElement.style) {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        window.scrollTo(0, 0);
      }
    });

    // Show after passing one viewport of scroll
    let ticking = false;
    const SHOW_AT = window.innerHeight * 0.9;

    const update = () => {
      const y = window.scrollY;
      btn.dataset.visible = String(y > SHOW_AT);
      ticking = false;
    };

    window.addEventListener(
      'scroll',
      () => {
        if (!ticking) {
          requestAnimationFrame(update);
          ticking = true;
        }
      },
      { passive: true },
    );
    update();

    // Hide when the footer is visible — footer already has a "Back to top ↑" link
    if (footer && 'IntersectionObserver' in window) {
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            btn.dataset.atFooter = String(e.isIntersecting);
          }
        },
        { threshold: 0.05, rootMargin: '0px 0px -8% 0px' },
      );
      io.observe(footer);
    }
  }
</script>
