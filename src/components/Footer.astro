---
import { site } from '../data/site';

const year = new Date().getFullYear();
---

<footer class="footer" id="footer">
  <div class="wrap">
    <div class="footer__top">
      <div class="footer__col footer__col--brand">
        <a href="#top" class="footer__wordmark" aria-label="XYVON home">
          <span>XYVON</span>
          <span class="footer__wordmark-dot" aria-hidden="true"></span>
        </a>
        <p class="footer__tag">SCIENCE-LED ELECTROLYTES</p>
        <p class="footer__addr">
          EU-made · Vitema EU GMP partnership ·
          <br />Phase 1: Romania · 2026 → EU expansion
        </p>
        <div class="footer__badges">
          {site.trust.slice(0, 4).map((t) => (
            <span class="footer__badge">{t}</span>
          ))}
        </div>
      </div>

      <div class="footer__col">
        <h4>Products</h4>
        <ul>
          <li><a href="#balance">BALANCE · Daily cycle-aware</a></li>
          <li><a href="#shift">SHIFT · Peri / post-menopause</a></li>
          <li><a href="#perform">PERFORM · Training</a></li>
          <li><a href="#recover">RECOVER · Evening recovery</a></li>
          <li><a href="#him">HIM · Daily for men</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Science</h4>
        <ul>
          <li><a href="#science">Why this dose</a></li>
          <li><a href="#substack">Read our Substack</a></li>
          <li><a href="/coa">Certificates of Analysis</a></li>
          <li><a href="/formulation">Formulation philosophy</a></li>
          <li><a href="/which-xyvon">Which XYVON is for you?</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4>Brand</h4>
        <ul>
          <li><a href="#story">The founder</a></li>
          <li><a href="/press">Press & assets</a></li>
          <li><a href="/contact">Contact</a></li>
          <li><a href={site.social.instagram} rel="me noopener" target="_blank">Instagram ↗</a></li>
          <li><a href={site.social.tiktok} rel="me noopener" target="_blank">TikTok ↗</a></li>
        </ul>
      </div>
    </div>

    <div class="footer__rule" aria-hidden="true"></div>

    <div class="footer__bottom">
      <p class="footer__legal">© {year} XYVON. Confidential until 2026 launch. All sachets zero sugar, zero fluff.</p>
      <ul class="footer__meta">
        <li><a href="/privacy">Privacy</a></li>
        <li><a href="/terms">Terms</a></li>
        <li><a href="/impressum">Impressum</a></li>
        <li><a href="#top">Back to top ↑</a></li>
      </ul>
    </div>

    <!-- Giant wordmark -->
    <div class="footer__mark" aria-hidden="true">XYVON</div>
  </div>
</footer>

<style>
  .footer {
    background: var(--xyv-black-deep);
    color: var(--ink-primary);
    padding-top: var(--sp-10);
    position: relative;
    border-top: 1px solid var(--xyv-line);
    overflow: hidden;
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2.2fr 1fr 1fr 1fr;
    gap: var(--sp-7);
    padding-bottom: var(--sp-8);
  }

  .footer__col { display: flex; flex-direction: column; gap: var(--sp-4); }

  .footer__col h4 {
    font-family: var(--font-display);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--xyv-copper);
    font-weight: 500;
    margin-bottom: var(--sp-2);
  }

  .footer__col ul { list-style: none; display: flex; flex-direction: column; gap: var(--sp-2); }
  .footer__col ul a {
    font-size: var(--fs-small);
    color: var(--ink-muted);
    transition: color var(--dur-fast) var(--ease-smooth), letter-spacing var(--dur-med) var(--ease-smooth);
  }
  .footer__col ul a:hover { color: var(--xyv-off-white); letter-spacing: 0.02em; }

  /* ---------- Brand column ---------- */
  .footer__wordmark {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.5rem;
    letter-spacing: var(--tracking-wordmark);
  }

  .footer__wordmark-dot {
    width: 7px;
    height: 7px;
    background: var(--xyv-copper);
    border-radius: 50%;
    animation: copper-pulse 2.4s var(--ease-in-out) infinite;
  }

  .footer__tag {
    font-family: var(--font-display);
    font-size: 0.7rem;
    letter-spacing: var(--tracking-caps-wide);
    text-transform: uppercase;
    color: var(--xyv-copper);
    font-weight: 500;
  }

  .footer__addr {
    font-size: var(--fs-small);
    color: var(--ink-muted);
    max-width: 42ch;
  }

  .footer__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
    margin-top: var(--sp-3);
  }

  .footer__badge {
    padding: 0.4em 0.9em;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--ink-muted);
    border: 1px solid var(--xyv-line-strong);
    border-radius: var(--r-pill);
  }

  .footer__rule {
    height: 1px;
    background: var(--xyv-line);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--sp-6);
    flex-wrap: wrap;
    gap: var(--sp-4);
  }

  .footer__legal { font-size: var(--fs-xs); color: var(--ink-faint); }

  .footer__meta { display: flex; gap: var(--sp-5); list-style: none; }
  .footer__meta a {
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-caps);
    color: var(--ink-muted);
  }
  .footer__meta a:hover { color: var(--xyv-copper); }

  /* ---------- Giant wordmark ---------- */
  .footer__mark {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(5rem, 24vw, 22rem);
    letter-spacing: -0.04em;
    line-height: 0.7;
    text-align: center;
    color: transparent;
    -webkit-text-stroke: 1px rgba(245, 242, 238, 0.08);
    padding-block: var(--sp-5) var(--sp-3);
    background:
      linear-gradient(180deg, rgba(245, 242, 238, 0.06), rgba(184, 115, 51, 0.14));
    -webkit-background-clip: text;
    background-clip: text;
    user-select: none;
  }

  @media (max-width: 960px) {
    .footer__top { grid-template-columns: 1fr 1fr; }
    .footer__col--brand { grid-column: 1 / -1; }
  }

  @media (max-width: 640px) {
    .footer__top {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer__col {
      align-items: center;
      text-align: center;
    }
    .footer__col--brand { align-items: center; }
    .footer__wordmark { justify-content: center; }
    .footer__addr { margin-inline: auto; }
    .footer__badges { justify-content: center; }

    .footer__col h4 { text-align: center; }
    .footer__col ul { align-items: center; }
    .footer__col ul li { text-align: center; }

    .footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: var(--sp-4);
    }
    .footer__meta {
      justify-content: center;
      flex-wrap: wrap;
      gap: var(--sp-4);
    }

    .footer__mark {
      font-size: clamp(3.5rem, 32vw, 12rem);
    }
  }
</style>
